# WordPress の基本設定です。

# WordPress 本体と DB のホスト公開ポートです。
APP_PORT=8080
DB_PORT=33060

# 永続化データの保存先です。
HOST_DATA_DIR=./data
WORDPRESS_HTML_DIR=./data/html
WORDPRESS_DB_DIR=./data/db

# reverse proxy とつなぐための network / alias です。
PROXY_NETWORK_NAME=proxy-network
WORDPRESS_PROXY_ALIAS=wordpress

# コンテナ内タイムゾーンです。
TZ=Asia/Tokyo

# DB の接続情報です。
# 初回は change-me のまま生成され、configure-default-envs.sh でも補完されます。
WORDPRESS_DB_NAME=wordpress
WORDPRESS_DB_USER=wordpress
WORDPRESS_DB_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-me-root
